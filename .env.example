# 服务器配置
PORT=3000
NODE_ENV=development

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=yujian

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT配置
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=24h

# ==================== 文件上传配置 ====================
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760

# ==================== CORS 跨域白名单 ====================
# 生产环境必须设置，多个域名用逗号分隔
# 示例: https://app.your-domain.com,https://admin.your-domain.com
ALLOWED_ORIGINS=http://localhost:3000

# ==================== 内测模拟模式 ====================
# 短信模拟：设为 true 时验证码固定为 123456，生产环境对接真实短信后设为 false
SMS_SIMULATE=true
# 支付模拟：设为 true 时自动确认支付/充值，生产环境对接微信支付宝后设为 false
SIMULATE_PAYMENT=true

# ==================== 短信服务配置 ====================
SMS_ACCESS_KEY=your_sms_access_key
SMS_SECRET_KEY=your_sms_secret_key

# ==================== 礼物分成比例 ====================
# 接收者收到礼物的金币分成比例（0~1），默认 0.7 即 70%
GIFT_SHARE_RATIO=0.7

# ==================== 阿里云OSS配置（生产环境，内测可忽略） ====================
# OSS_REGION=your_oss_region
# OSS_ACCESS_KEY=your_oss_access_key
# OSS_SECRET_KEY=your_oss_secret_key
# OSS_BUCKET=your_oss_bucket

# ==================== 限流配置 ====================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100